{
  "name": "Phishing Report Analysis — POP3/Graph Mail",
  "description": "Analisi automatica delle segnalazioni di phishing. Estrae IOC dall'email originale allegata, arricchisce con VirusTotal (URL loop + IP) e WHOIS in parallelo. Score enrichment critico (<=20) cortocircuita a ESCALATED+HIGH. Trusted bypass solo su URL clean. Soglie: malicious>=5 → ESCALATED+HIGH, >=3 → RESOLVED+MEDIUM, altrimenti RESOLVED+LOW.",
  "status": "ACTIVE",
  "tags": [
    "phishing",
    "email-security",
    "virustotal",
    "whois",
    "enrichment",
    "automated-response"
  ],
  "definition": {
    "nodes": [
      {
        "id": "n1-trigger",
        "type": "trigger",
        "position": {
          "x": 400,
          "y": 50
        },
        "data": {
          "label": "Phishing Report Received",
          "nodeType": "INCIDENT_CREATED",
          "config": {
            "incidentType": ""
          }
        }
      },
      {
        "id": "n2-check-subject",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 200
        },
        "data": {
          "label": "Is Phishing Report?",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{incident.title}} contains New Feedback from"
          }
        }
      },
      {
        "id": "n3-noop-exit",
        "type": "action",
        "position": {
          "x": 750,
          "y": 200
        },
        "data": {
          "label": "Not Phishing — Exit",
          "nodeType": "NO_OP",
          "config": {}
        }
      },
      {
        "id": "n4-extract-reporter",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 360
        },
        "data": {
          "label": "Extract Reporter Email",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{incident.title}}",
            "outputPath": "phishing_reporter",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "New Feedback from .([a-zA-Z0-9._%+@\\-]+) reporting",
                  "flags": "i",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n5-extract-reported",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 520
        },
        "data": {
          "label": "Extract Reported Email",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{incident.title}}",
            "outputPath": "phishing_reported_email",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "reporting .([a-zA-Z0-9._%+@\\-]+)",
                  "flags": "i",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n6-extract-reported-domain",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 680
        },
        "data": {
          "label": "Extract Reported Domain",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{phishing_reported_email}}",
            "outputPath": "phishing_reported_domain",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "([a-zA-Z0-9-]+\\.[a-zA-Z]{2,})$",
                  "flags": "i",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n7-extract-feedback",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 840
        },
        "data": {
          "label": "Extract User Feedback",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{email.bodyText}}",
            "outputPath": "phishing_user_feedback",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "Additional user feedback:\\s*(.+?)(?:\\n|$)",
                  "flags": "is",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n8-write-context",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1000
        },
        "data": {
          "label": "Store Reporter",
          "nodeType": "WRITE_CONTEXT",
          "config": {
            "path": "phishing.reporter",
            "value": "{{phishing_reporter}}"
          }
        }
      },
      {
        "id": "n8b-write-reported",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1100
        },
        "data": {
          "label": "Store Reported Email",
          "nodeType": "WRITE_CONTEXT",
          "config": {
            "path": "phishing.reported",
            "value": "{{phishing_reported_email}}"
          }
        }
      },
      {
        "id": "n8c-write-feedback",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1200
        },
        "data": {
          "label": "Store User Feedback",
          "nodeType": "WRITE_CONTEXT",
          "config": {
            "path": "phishing.user_feedback",
            "value": "{{phishing_user_feedback}}"
          }
        }
      },
      {
        "id": "n8d-read-eml",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1360
        },
        "data": {
          "label": "Read Original Phishing Email",
          "nodeType": "READ_ATTACHMENT",
          "config": {
            "mimeType": "message/rfc822",
            "outputPath": "eml_content"
          }
        }
      },
      {
        "id": "n8e-read-headers",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1500
        },
        "data": {
          "label": "Read Email Headers",
          "nodeType": "READ_ATTACHMENT",
          "config": {
            "fileName": "headers.txt",
            "outputPath": "headers_content"
          }
        }
      },
      {
        "id": "n9-extract-urls",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1660
        },
        "data": {
          "label": "Extract URLs from EML",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{eml_content}}",
            "outputPath": "phishing_urls",
            "transformations": [
              {
                "id": "t1",
                "type": "extract_urls",
                "params": {}
              },
              {
                "id": "t2",
                "type": "unique",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n10-extract-ips",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1820
        },
        "data": {
          "label": "Extract IPs from Headers",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{headers_content}}",
            "outputPath": "phishing_ips",
            "transformations": [
              {
                "id": "t1",
                "type": "extract_ips",
                "params": {}
              },
              {
                "id": "t2",
                "type": "unique",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n11-first-url",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1980
        },
        "data": {
          "label": "Get First URL",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{phishing_urls}}",
            "outputPath": "phishing_first_url",
            "transformations": [
              {
                "id": "t1",
                "type": "first",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n12-first-ip",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 2140
        },
        "data": {
          "label": "Get First IP",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{phishing_ips}}",
            "outputPath": "phishing_first_ip",
            "transformations": [
              {
                "id": "t1",
                "type": "first",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n12b-add-iocs",
        "type": "action",
        "position": {
          "x": 400,
          "y": 2300
        },
        "data": {
          "label": "Add IOCs to Incident",
          "nodeType": "ADD_IOCS",
          "config": {
            "urlsPath": "phishing_urls",
            "ipsPath": "phishing_ips"
          }
        }
      },
      {
        "id": "n-par1-outer",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 2440
        },
        "data": {
          "label": "Parallel Enrichment",
          "nodeType": "PARALLEL",
          "config": {}
        }
      },
      {
        "id": "n14c-vt-ip",
        "type": "integration",
        "position": {
          "x": 120,
          "y": 2620
        },
        "data": {
          "label": "VT — IP Lookup",
          "nodeType": "INTEGRATION_ACTION",
          "config": {
            "integrationSlug": "virustotal",
            "actionSlug": "lookup_ip",
            "installedIntegrationId": "",
            "outputVariable": "vt_ip",
            "inputs": {
              "ip": "{{phishing_first_ip}}"
            }
          }
        }
      },
      {
        "id": "n-par2-inner",
        "type": "logic",
        "position": {
          "x": 680,
          "y": 2620
        },
        "data": {
          "label": "WHOIS + VT URLs",
          "nodeType": "PARALLEL",
          "config": {}
        }
      },
      {
        "id": "n14d-whois",
        "type": "integration",
        "position": {
          "x": 500,
          "y": 2800
        },
        "data": {
          "label": "WHOIS — Domain Lookup",
          "nodeType": "INTEGRATION_ACTION",
          "config": {
            "integrationSlug": "whois-rdap",
            "actionSlug": "lookup_domain",
            "installedIntegrationId": "",
            "outputVariable": "whois_domain",
            "inputs": {
              "domain": "{{phishing_reported_domain}}"
            }
          }
        }
      },
      {
        "id": "n15b-loop-vt-urls",
        "type": "logic",
        "position": {
          "x": 860,
          "y": 2800
        },
        "data": {
          "label": "VT Scan All URLs",
          "nodeType": "LOOP",
          "config": {
            "arrayPath": "phishing_urls",
            "itemVariable": "loop_url",
            "resultVariable": "vt_url_scan_results",
            "maxItems": "10",
            "bodyAction": {
              "type": "INTEGRATION_ACTION",
              "integrationSlug": "virustotal",
              "actionSlug": "lookup_url",
              "installedIntegrationId": "",
              "inputs": {
                "url": "{{loop_url}}"
              },
              "outputVariable": "vt_loop_url_result"
            }
          }
        }
      },
      {
        "id": "n15f-loop-detonate-urls",
        "type": "logic",
        "position": {
          "x": 860,
          "y": 2960
        },
        "data": {
          "label": "Detonate All Phishing URLs",
          "nodeType": "LOOP",
          "config": {
            "arrayPath": "phishing_urls",
            "itemVariable": "detonate_url",
            "resultVariable": "sandbox_url_results",
            "maxItems": "5",
            "bodyAction": {
              "type": "DETONATE_URL",
              "sandbox": "any_run"
            }
          }
        }
      },
      {
        "id": "n15g-delay",
        "type": "action",
        "position": {
          "x": 860,
          "y": 3120
        },
        "data": {
          "label": "Wait for Sandbox Results (5 min)",
          "nodeType": "DELAY",
          "config": {
            "duration": "5",
            "unit": "minutes"
          }
        }
      },
      {
        "id": "n15-merge",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 3280
        },
        "data": {
          "label": "All Enrichments Complete",
          "nodeType": "MERGE",
          "config": {}
        }
      },
      {
        "id": "n15d-update-ioc-scores",
        "type": "action",
        "position": {
          "x": 400,
          "y": 3440
        },
        "data": {
          "label": "Update IOC Scores from VT",
          "nodeType": "UPDATE_IOC_SCORES",
          "config": {}
        }
      },
      {
        "id": "n15e-if-enrichment-critical",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 3560
        },
        "data": {
          "label": "Enrichment Score Critical? (<=20)",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{ioc_risk_score}} <= 20"
          }
        }
      },
      {
        "id": "n15c-url-max",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 3720
        },
        "data": {
          "label": "Extract URL Max Malicious",
          "nodeType": "JMESPATH",
          "config": {
            "query": "(vt_url_scan_results || `[]`)[].malicious | [?@ != `null`] | max(@)",
            "output_var": "url_max_malicious"
          }
        }
      },
      {
        "id": "n16-compute-score",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 3880
        },
        "data": {
          "label": "Compute Total Malicious Score",
          "nodeType": "JMESPATH",
          "config": {
            "query": "[url_max_malicious, vt_ip.malicious, vt_domain.malicious] | [?@ != `null`] | max(@) || `0`",
            "output_var": "total_malicious"
          }
        }
      },
      {
        "id": "n16b-harmless-score",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 4040
        },
        "data": {
          "label": "Extract Harmless Score",
          "nodeType": "JMESPATH",
          "config": {
            "query": "(vt_url_scan_results || `[]`)[?malicious == `0`].harmless | [?@ != `null`] | max(@) || `0`",
            "output_var": "harmless_score"
          }
        }
      },
      {
        "id": "n17b-if-trusted",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 4200
        },
        "data": {
          "label": "Trusted Domain? (harmless >= 10)",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{harmless_score}} >= 10"
          }
        }
      },
      {
        "id": "n17-if-attachments",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 4360
        },
        "data": {
          "label": "Has Suspicious URL?",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{phishing_first_url}} != "
          }
        }
      },
      {
        "id": "n18-detonate-url",
        "type": "sandbox",
        "position": {
          "x": 150,
          "y": 4520
        },
        "data": {
          "label": "Detonate Suspicious URL",
          "nodeType": "DETONATE_URL",
          "config": {
            "url": "{{phishing_first_url}}",
            "sandbox": "any_run"
          }
        }
      },
      {
        "id": "n19-if-malicious",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 4680
        },
        "data": {
          "label": "High Risk? (malicious >= 5)",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{total_malicious}} >= 5"
          }
        }
      },
      {
        "id": "n20-update-high",
        "type": "action",
        "position": {
          "x": 120,
          "y": 4840
        },
        "data": {
          "label": "Set ESCALATED — Phishing Confirmed",
          "nodeType": "UPDATE_INCIDENT",
          "config": {
            "severity": "HIGH",
            "status": "ESCALATED",
            "notes": "PHISHING CONFIRMED — ESCALATED per analisi SOC. VT malicious: {{total_malicious}}, enrichment score: {{ioc_risk_score}}. Reported: {{phishing_reported_email}}. Registrar: {{whois_domain.registrar}}. Feedback: {{phishing_user_feedback}}"
          }
        }
      },
      {
        "id": "n21-notify-soc-high",
        "type": "human",
        "position": {
          "x": 120,
          "y": 5000
        },
        "data": {
          "label": "Notify SOC — Phishing Confirmed",
          "nodeType": "NOTIFICATION",
          "config": {
            "message": "PHISHING CONFIRMED ({{total_malicious}} VT detections, score {{ioc_risk_score}}). Reporter: {{phishing_reporter}} | Reported: {{phishing_reported_email}} | Domain: {{phishing_reported_domain}}",
            "targetType": "all_analysts"
          }
        }
      },
      {
        "id": "n22-email-malicious",
        "type": "action",
        "position": {
          "x": 120,
          "y": 5160
        },
        "data": {
          "label": "Email Reporter — Phishing Confirmed",
          "nodeType": "SEND_EMAIL",
          "config": {
            "to": "{{email.from}}",
            "subject": "Phishing Report Confirmed — {{phishing_reported_email}}",
            "body": "Dear {{email.from}},\n\nThank you for reporting the suspicious email from {{phishing_reported_email}}.\n\nVERDICT: PHISHING CONFIRMED — ESCALATED\n\nOur automated analysis detected {{total_malicious}} malicious indicators. The incident has been escalated to our SOC team for immediate investigation.\n\nDetails:\n- Reported sender: {{phishing_reported_email}}\n- Domain: {{phishing_reported_domain}}\n- Domain registration: {{whois_domain.registrar}}\n- VirusTotal (IP): {{vt_ip.malicious}} malicious\n- Enrichment risk score: {{ioc_risk_score}}/100 (lower = more dangerous)\n\nRecommendations:\n1. Do NOT click any links in the reported email\n2. Do NOT open any attachments\n3. If you already interacted with the email, contact IT Security immediately\n\nYour feedback: \"{{phishing_user_feedback}}\"\n\nCyber SOAR — Security Operations Center\nIncident Reference: {{incidentId}}"
          }
        }
      },
      {
        "id": "n22b-sms-admin",
        "type": "action",
        "position": {
          "x": 120,
          "y": 5320
        },
        "data": {
          "label": "SMS Admin — Phishing Alert",
          "nodeType": "SEND_SMS",
          "config": {
            "to": "+39XXXXXXXXXX",
            "message": "CYBER SOAR [HIGH ESCALATED] Phishing confermato: {{phishing_reported_email}} ({{total_malicious}} VT detections, score {{ioc_risk_score}}). Incident: {{incidentId}}. Reporter: {{email.from}}"
          }
        }
      },
      {
        "id": "n23-if-suspicious",
        "type": "logic",
        "position": {
          "x": 680,
          "y": 4840
        },
        "data": {
          "label": "Suspicious? (malicious >= 3)",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{total_malicious}} >= 3"
          }
        }
      },
      {
        "id": "n24-update-medium",
        "type": "action",
        "position": {
          "x": 560,
          "y": 5000
        },
        "data": {
          "label": "Set MEDIUM Risk — Under Review",
          "nodeType": "UPDATE_INCIDENT",
          "config": {
            "severity": "MEDIUM",
            "status": "RESOLVED",
            "notes": "SUSPICIOUS (auto-resolved) — VT malicious: {{total_malicious}}, score: {{ioc_risk_score}}. Reported: {{phishing_reported_email}}. Feedback: {{phishing_user_feedback}}"
          }
        }
      },
      {
        "id": "n25-email-suspicious",
        "type": "action",
        "position": {
          "x": 560,
          "y": 5160
        },
        "data": {
          "label": "Email Reporter — Under Review",
          "nodeType": "SEND_EMAIL",
          "config": {
            "to": "{{email.from}}",
            "subject": "Phishing Report Under Review — {{phishing_reported_email}}",
            "body": "Dear {{email.from}},\n\nThank you for reporting the suspicious email from {{phishing_reported_email}}.\n\nVERDICT: SUSPICIOUS — UNDER REVIEW\n\nOur automated analysis detected {{total_malicious}} indicator(s) that require manual review.\n\nDetails:\n- Reported sender: {{phishing_reported_email}}\n- Domain: {{phishing_reported_domain}}\n- VirusTotal (IP): {{vt_ip.malicious}} malicious\n\nRecommendation: Exercise caution. Do not click links or open attachments until you receive our final verdict.\n\nYour feedback: \"{{phishing_user_feedback}}\"\n\nCyber SOAR — Security Operations Center\nIncident Reference: {{incidentId}}"
          }
        }
      },
      {
        "id": "n26-update-low",
        "type": "action",
        "position": {
          "x": 860,
          "y": 4840
        },
        "data": {
          "label": "Set LOW Risk — No Threat",
          "nodeType": "UPDATE_INCIDENT",
          "config": {
            "severity": "LOW",
            "status": "RESOLVED",
            "notes": "LOW RISK — VT malicious: {{total_malicious}}, harmless: {{harmless_score}}, score: {{ioc_risk_score}}. Reported: {{phishing_reported_email}}. Feedback: {{phishing_user_feedback}}"
          }
        }
      },
      {
        "id": "n27-email-clean",
        "type": "action",
        "position": {
          "x": 860,
          "y": 5000
        },
        "data": {
          "label": "Email Reporter — No Threat Detected",
          "nodeType": "SEND_EMAIL",
          "config": {
            "to": "{{email.from}}",
            "subject": "Phishing Report Reviewed — No Threat Detected — {{phishing_reported_email}}",
            "body": "Dear {{email.from}},\n\nThank you for reporting the email from {{phishing_reported_email}}.\n\nVERDICT: NO THREAT DETECTED\n\nOur automated analysis did not find significant malicious indicators.\n\nDetails:\n- Reported sender: {{phishing_reported_email}}\n- Domain: {{phishing_reported_domain}}\n- VirusTotal harmless votes: {{harmless_score}} (trusted threshold: 10)\n- WHOIS registration: {{whois_domain.registrar}}\n\nThe email appears to be from a legitimate sender. If you continue to feel uncertain, please contact your IT Security team.\n\nYour feedback: \"{{phishing_user_feedback}}\"\n\nCyber SOAR — Security Operations Center\nIncident Reference: {{incidentId}}"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1-2",
        "source": "n1-trigger",
        "target": "n2-check-subject"
      },
      {
        "id": "e2f-3",
        "source": "n2-check-subject",
        "target": "n3-noop-exit",
        "sourceHandle": "false",
        "label": "Not phishing report"
      },
      {
        "id": "e2t-4",
        "source": "n2-check-subject",
        "target": "n4-extract-reporter",
        "sourceHandle": "true",
        "label": "Is phishing report"
      },
      {
        "id": "e4-5",
        "source": "n4-extract-reporter",
        "target": "n5-extract-reported"
