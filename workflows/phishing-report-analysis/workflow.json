          "config": {
            "severity": "LOW",
            "status": "RESOLVED",
            "notes": "LOW RISK — VT malicious: {{total_malicious}}, harmless: {{harmless_score}} (trusted if >= 10). Reported: {{phishing_reported_email}}. Feedback: {{phishing_user_feedback}}"
          }
        }
      },
      {
        "id": "n27-email-clean",
        "type": "action",
        "position": {
          "x": 860,
          "y": 3860
        },
        "data": {
          "label": "Email Reporter — No Threat Detected",
          "nodeType": "SEND_EMAIL",
          "config": {
            "to": "{{email.from}}",
            "subject": "Phishing Report Reviewed — No Threat Detected — {{phishing_reported_email}}",
            "body": "Dear {{email.from}},\n\nThank you for reporting the email from {{phishing_reported_email}}.\n\nVERDICT: NO THREAT DETECTED\n\nOur automated analysis did not find significant malicious indicators for the reported sender.\n\nDetails:\n- Reported sender: {{phishing_reported_email}}\n- Domain: {{phishing_reported_domain}}\n- VirusTotal malicious: {{vt_domain.malicious}}\n- VirusTotal harmless: {{vt_domain.harmless}} (trusted domain threshold: 10)\n- WHOIS registration: {{whois_domain.registrar}}\n\nThe email appears to be from a legitimate sender. If you continue to feel uncertain, please contact your IT Security team.\n\nYour feedback: \"{{phishing_user_feedback}}\"\n\nCyber SOAR — Security Operations Center\nIncident Reference: {{incidentId}}"
          }
        }
      }
