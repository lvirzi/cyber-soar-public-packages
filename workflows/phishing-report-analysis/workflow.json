{
  "name": "Phishing Report Analysis — POP3/Graph Mail",
  "description": "Analisi automatica delle segnalazioni di phishing. Estrae IOC, esegue enrichment parallelo con VirusTotal e WHOIS. Tuning: se il dominio ha >= 10 voti harmless su VT → trusted (LOW, no alert); se malicious >= 5 → HIGH; se malicious >= 3 → MEDIUM; altrimenti LOW.",
  "status": "ACTIVE",
  "tags": [
    "phishing",
    "email-security",
    "virustotal",
    "whois",
    "enrichment",
    "automated-response"
  ],
  "definition": {
    "nodes": [
      {
        "id": "n1-trigger",
        "type": "trigger",
        "position": {
          "x": 400,
          "y": 40
        },
        "data": {
          "label": "Phishing Report Received",
          "nodeType": "INCIDENT_CREATED",
          "config": {
            "incidentType": ""
          }
        }
      },
      {
        "id": "n2-check-subject",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 180
        },
        "data": {
          "label": "Is Phishing Report?",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{incident.title}} contains New Feedback from"
          }
        }
      },
      {
        "id": "n3-noop-exit",
        "type": "action",
        "position": {
          "x": 700,
          "y": 180
        },
        "data": {
          "label": "Not a Phishing Report — Exit",
          "nodeType": "NO_OP",
          "config": {}
        }
      },
      {
        "id": "n4-extract-reporter",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 340
        },
        "data": {
          "label": "Extract Reporter Email",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{incident.title}}",
            "outputPath": "phishing_reporter",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "New Feedback from .([a-zA-Z0-9._%+@\\-]+) reporting",
                  "flags": "i",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n5-extract-reported",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 500
        },
        "data": {
          "label": "Extract Reported Email",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{incident.title}}",
            "outputPath": "phishing_reported_email",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "reporting .([a-zA-Z0-9._%+@\\-]+)",
                  "flags": "i",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n6-extract-reported-domain",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 660
        },
        "data": {
          "label": "Extract Reported Domain",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{phishing_reported_email}}",
            "outputPath": "phishing_reported_domain",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "([a-zA-Z0-9-]+\\.[a-zA-Z]{2,})$",
                  "flags": "i",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n7-extract-feedback",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 820
        },
        "data": {
          "label": "Extract User Feedback",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{email.bodyText}}",
            "outputPath": "phishing_user_feedback",
            "transformations": [
              {
                "id": "t1",
                "type": "regex_extract",
                "params": {
                  "pattern": "Additional user feedback:\\s*(.+?)(?:\\n|$)",
                  "flags": "is",
                  "group": "1"
                }
              },
              {
                "id": "t2",
                "type": "trim",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n8-write-context",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 980
        },
        "data": {
          "label": "Store Reporter in Context",
          "nodeType": "WRITE_CONTEXT",
          "config": {
            "path": "phishing.reporter",
            "value": "{{phishing_reporter}}"
          }
        }
      },
      {
        "id": "n8b-write-reported",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1100
        },
        "data": {
          "label": "Store Reported Email",
          "nodeType": "WRITE_CONTEXT",
          "config": {
            "path": "phishing.reported",
            "value": "{{phishing_reported_email}}"
          }
        }
      },
      {
        "id": "n8c-write-feedback",
