          }
        }
      },
      {
        "id": "n25-email-suspicious",
        "type": "action",
        "position": {
          "x": 560,
          "y": 4020
        },
        "data": {
          "label": "Email Reporter — Under Review",
          "nodeType": "SEND_EMAIL",
          "config": {
            "to": "{{email.from}}",
            "subject": "Phishing Report Under Review — {{phishing_reported_email}}",
            "body": "Dear {{email.from}},\n\nThank you for reporting the suspicious email from {{phishing_reported_email}}.\n\nVERDICT: SUSPICIOUS — UNDER REVIEW\n\nOur automated analysis detected {{total_malicious}} indicator(s) that require manual review.\n\nDetails:\n- Reported sender: {{phishing_reported_email}}\n- Domain: {{phishing_reported_domain}}\n- VirusTotal malicious: {{vt_domain.malicious}}\n- VirusTotal harmless: {{vt_domain.harmless}}\n\nRecommendation: Exercise caution with this email. Do not click links or open attachments until you receive our final verdict.\n\nYour feedback: \"{{phishing_user_feedback}}\"\n\nCyber SOAR — Security Operations Center\nIncident Reference: {{incidentId}}"
          }
        }
      },
      {
        "id": "n26-update-low",
