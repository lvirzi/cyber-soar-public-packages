        "data": {
          "label": "Extract Malicious Score",
          "nodeType": "JMESPATH",
          "config": {
            "query": "vt_domain.malicious",
            "output_var": "total_malicious"
          }
        }
      },
      {
        "id": "n16b-harmless-score",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 2860
        },
        "data": {
          "label": "Extract Harmless Score",
          "nodeType": "JMESPATH",
          "config": {
            "query": "vt_domain.harmless",
            "output_var": "harmless_score"
          }
        }
      },
      {
        "id": "n17b-if-trusted",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 3000
        },
        "data": {
          "label": "Trusted Domain? (harmless >= 10)",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{harmless_score}} >= 10"
          }
        }
      },
      {
        "id": "n17-if-attachments",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 3160
        },
        "data": {
          "label": "Has Suspicious URL?",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{phishing_first_url}} != "
          }
        }
      },
      {
        "id": "n18-detonate-url",
        "type": "sandbox",
        "position": {
          "x": 120,
          "y": 3340
        },
        "data": {
          "label": "Detonate Suspicious URL",
          "nodeType": "DETONATE_URL",
          "config": {
            "url": "{{phishing_first_url}}",
            "sandbox": "any_run"
          }
        }
      },
      {
        "id": "n19-if-malicious",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 3520
        },
        "data": {
          "label": "High Risk? (malicious >= 5)",
          "nodeType": "IF_ELSE",
          "config": {
            "condition": "{{total_malicious}} >= 5"
          }
        }
      },
      {
        "id": "n20-update-high",
        "type": "action",
        "position": {
          "x": 120,
          "y": 3700
        },
        "data": {
          "label": "Set HIGH Risk — Phishing Confirmed",
          "nodeType": "UPDATE_INCIDENT",
          "config": {
            "severity": "HIGH",
            "status": "RESOLVED",
            "notes": "PHISHING CONFIRMED (auto-resolved) — VT malicious: {{total_malicious}}, harmless: {{harmless_score}}. Reported: {{phishing_reported_email}}. Registrar: {{whois_domain.registrar}}. Feedback: {{phishing_user_feedback}}"
          }
        }
      },
      {
        "id": "n21-notify-soc-high",
        "type": "human",
        "position": {
          "x": 120,
          "y": 3860
        },
        "data": {
          "label": "Notify SOC — Phishing Confirmed",
          "nodeType": "NOTIFICATION",
          "config": {
            "message": "PHISHING CONFIRMED — {{total_malicious}} VT detections (harmless: {{harmless_score}}). Reporter: {{phishing_reporter}} | Reported: {{phishing_reported_email}} | Domain: {{phishing_reported_domain}}",
            "targetType": "all_analysts"
          }
        }
      },
      {
        "id": "n22-email-malicious",
        "type": "action",
        "position": {
          "x": 120,
          "y": 4020
        },
        "data": {
          "label": "Email Reporter — Phishing Confirmed",
          "nodeType": "SEND_EMAIL",
          "config": {
            "to": "{{email.from}}",
            "subject": "Phishing Report Confirmed — {{phishing_reported_email}}",
            "body": "Dear {{email.from}},\n\nThank you for reporting the suspicious email from {{phishing_reported_email}}.\n\nVERDICT: PHISHING CONFIRMED\n\nOur automated analysis detected {{total_malicious}} malicious indicators (VT harmless votes: {{harmless_score}}).\n\nDetails:\n- Reported sender: {{phishing_reported_email}}\n- Domain: {{phishing_reported_domain}}\n- Domain registration: {{whois_domain.registrar}}\n- VirusTotal malicious: {{vt_domain.malicious}}\n- VirusTotal suspicious: {{vt_domain.suspicious}}\n- VirusTotal harmless: {{vt_domain.harmless}}\n\nAction taken: The incident has been escalated to our SOC team.\n\nRecommendations:\n1. Do NOT click any links in the reported email\n2. Do NOT open any attachments\n3. If you already interacted with the email, contact IT Security immediately\n\nYour feedback: \"{{phishing_user_feedback}}\"\n\nCyber SOAR — Security Operations Center\nIncident Reference: {{incidentId}}"
          }
        }
      },
      {
        "id": "n22b-sms-admin",
        "type": "action",
        "position": {
          "x": 120,
          "y": 4180
        },
