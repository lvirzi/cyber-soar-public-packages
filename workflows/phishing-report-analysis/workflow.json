            "actionSlug": "lookup_domain",
            "installedIntegrationId": "",
            "outputVariable": "whois_domain",
            "inputs": {
              "domain": "{{phishing_reported_domain}}"
            }
          }
        }
      },
      {
        "id": "n15-merge",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 2560
        },
        "data": {
          "label": "Merge Enrichment Results",
          "nodeType": "MERGE",
          "config": {}
        }
      },
      {
        "id": "n16-compute-score",
        "type": "transform",
        "position": {
