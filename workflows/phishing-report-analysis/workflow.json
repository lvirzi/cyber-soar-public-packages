        "position": {
          "x": 400,
          "y": 1220
        },
        "data": {
          "label": "Store User Feedback",
          "nodeType": "WRITE_CONTEXT",
          "config": {
            "path": "phishing.user_feedback",
            "value": "{{phishing_user_feedback}}"
          }
        }
      },
      {
        "id": "n9-extract-urls",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1380
        },
        "data": {
          "label": "Extract URLs from Body",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{email.bodyText}}",
            "outputPath": "phishing_urls",
            "transformations": [
              {
                "id": "t1",
                "type": "extract_urls",
                "params": {}
              },
              {
                "id": "t2",
                "type": "unique",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n10-extract-ips",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1540
        },
        "data": {
          "label": "Extract IPs from Body",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{email.bodyText}}",
            "outputPath": "phishing_ips",
            "transformations": [
              {
                "id": "t1",
                "type": "extract_ips",
                "params": {}
              },
              {
                "id": "t2",
                "type": "unique",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n11-first-url",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1700
        },
        "data": {
          "label": "Get First URL",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{phishing_urls}}",
            "outputPath": "phishing_first_url",
            "transformations": [
              {
                "id": "t1",
                "type": "first",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n12-first-ip",
        "type": "transform",
        "position": {
          "x": 400,
          "y": 1860
        },
        "data": {
          "label": "Get First IP",
          "nodeType": "DATA_TRANSFORM",
          "config": {
            "inputExpression": "{{phishing_ips}}",
            "outputPath": "phishing_first_ip",
            "transformations": [
              {
                "id": "t1",
                "type": "first",
                "params": {}
              }
            ]
          }
        }
      },
      {
        "id": "n13-parallel",
        "type": "logic",
        "position": {
          "x": 400,
          "y": 2020
        },
        "data": {
          "label": "Parallel Enrichment",
          "nodeType": "PARALLEL",
          "config": {}
        }
      },
